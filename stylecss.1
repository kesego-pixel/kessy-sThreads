/* =========================
   GLOBAL RESET
========================= */

*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* =========================
   BODY
========================= */

body{
    font-family: 'Poppins', sans-serif;
    background-color: #f5f5f5;
    color: #333;
    line-height: 1.6;
}

/* =========================
   NAVBAR
========================= */

nav{
    background-color: #111;
    padding: 18px 40px;

    display: flex;
    justify-content: space-between;
    align-items: center;

    position: sticky;
    top: 0;
    z-index: 1000;
}

nav h1,
.logo{
    color:black;
    font-size: 2rem;
    font-weight: bold;
    letter-spacing: 2px;
}

nav ul{
    display: flex;
    list-style: none;
    gap: 30px;
}

nav ul li a{
    color: black;
    text-decoration: none;
    font-size: 1rem;
    transition: 0.3s;
}

nav ul li a:hover{
    color: #d4af37;
}

/* =========================
   HERO SECTION
========================= */

.hero{
    height: 100vh;

    background:
    linear-gradient(rgba(0,0,0,0.5),
    rgba(0,0,0,0.5)),
    url('images/FLYER.jpg');

    background-size: cover;
    background-position: center;

    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;

    color: white;
    padding: 20px;
}

.hero-content h1{
    font-size: 4rem;
    margin-bottom: 20px;
    letter-spacing: 3px;
}

.hero-content p{
    font-size: 1.3rem;
    margin-bottom: 30px;
}

/* =========================
   BUTTONS
========================= */

button,
.btn{
    background-color: #111;
    color: block;

    padding: 12px 25px;

    border: none;
    border-radius: 30px;

    cursor: pointer;

    transition: 0.3s;
}

button:hover,
.btn:hover{
    background-color: #d4af37;
    transform: scale(1.05);
}

/* =========================
   SECTIONS
========================= */

section{
    padding: 70px 50px;
}

section h2{
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 40px;
    color: #111;
}

/* =========================
   PRODUCT SECTION
========================= */

.product-container{
    display: grid;

    grid-template-columns:
    repeat(auto-fit, minmax(250px,1fr));

    gap: 30px;
}
.product-card{
    background-color: white;

    border-radius: 15px;

    overflow: hidden;

    box-shadow: 0 5px 15px rgba(0,0,0,0.1);

    transition: 0.3s;
}

.product-card:hover{
    transform: translateY(-10px);
}

.product-card img{
    width: 100%;
    height: 300px;
    object-fit: cover;
}

.product-info{
    padding: 20px;
}

.product-info h3{
    margin-bottom: 10px;
    font-size: 1.2rem;
}

.product-info p{
    color: #777;
    margin-bottom: 15px;
}

/* =========================
   ABOUT SECTION
========================= */

.about{
    background-color: white;
    border-radius: 20px;
    padding: 50px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
}

/* =========================
   CONTACT FORM
========================= */

form{
    max-width: 600px;
    margin: auto;

    display: flex;
    flex-direction: column;

    gap: 20px;
}

input,
textarea{
    padding: 15px;

    border: 1px solid #ccc;
    border-radius: 10px;

    font-size: 1rem;
}

textarea{
    min-height: 150px;
    resize: vertical;
}

input:focus,
textarea:focus{
    outline: none;
    border-color: #d4af37;
}

/* =========================
   FOOTER
========================= */

footer{
    background-color: #111;
    color: white;

    text-align: center;

    padding: 30px;
    margin-top: 50px;
}

/* =========================
   IMAGES
========================= */

img{
    max-width: 100%;
    display: block;
}

/* =========================
   SMOOTH SCROLL
========================= */

html{
    scroll-behavior: smooth;
}

/* =========================
   MOBILE RESPONSIVE
========================= */

@media(max-width:768px){

    nav{
        flex-direction: column;
        padding: 20px;
    }

    nav ul{
        flex-direction: column;
        text-align: center;
        margin-top: 20px;
        gap: 15px;
    }

    .hero-content h1{
        font-size: 2.5rem;
    }

    .hero-content p{
        font-size: 1rem;
    }

    section{
        padding: 50px 20px;
    }

    .about{
        padding: 30px;
    }

    .product-card img{
        height: 250px;
    }
}